        "l": true
    },
    {
        "id": "bf9379fa210a8ecc",
        "type": "function",
        "z": "20080e9522dba17a",
        "g": "0f9186a82e87dfc2",
        "name": "publishData",
        "func": "const client = global.get(\"mqttClient\");\n\nif (!client || !client.connected) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"Broker offline\" });\n    node.error(\"Falha ao publicar: Cliente MQTT desconectado.\", msg);\n    // TODO: Fazer o store-and-forward\n    return;\n}\n\nconst topic = msg.topic;\nconst bufferPayload = msg.payload;\n\nclient.publish(topic, bufferPayload, { qos: 0, retain: false }, (/** @type {NodeMessage} */ err) => {\n    if (err) {\n        node.error(`Erro ao publicar no tópico ${topic}: `, err);\n        node.status({ fill: \"red\", shape: \"dot\", text: \"Erro de I/O\" });\n    } else {\n        node.status({ fill: \"green\", shape: \"dot\", text: \"Publicado\" });\n    }\n});",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 930,
        "y": 200,
        "wires": [
            []
        ]
    },
    {
        "id": "d5ea1ef0df385798",
        "type": "link out",
