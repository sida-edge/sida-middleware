    {
        "id": "1eed795d89c44e79",
        "type": "link in",
        "z": "f4a91dd7bfc833e7",
        "g": "ba6a1b32fd321ca2",
        "name": "Receiver Queue",
        "links": [
            "b6034584ef370295"
        ],
        "x": 140,
        "y": 140,
