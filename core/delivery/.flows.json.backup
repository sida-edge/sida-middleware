    {
        "id": "0b6e40380fc4820f",
        "type": "inject",
        "z": "f4a91dd7bfc833e7",
        "name": "Semantic Data ",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "1",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "{\"timestamp\":1684512000000,\"gateway_id\":\"sida_edge_001\",\"isa95_context\":{\"enterprise\":\"SENAI\",\"site\":\"Recife\",\"area\":\"Producao\",\"line\":\"Envase\",\"equipment\":\"Esteira_A\"},\"data\":{\"velocidade_motor\":45.5,\"motor_ligado\":true}}",
        "payloadType": "json",
        "x": 200,
        "y": 140,
        "wires": [
            [
                "50b1232778c14788"
            ]
        ]
    },
    {
        "id": "a2c12bcdbb991cf7",
        "type": "function",
        "z": "f4a91dd7bfc833e7",
        "name": "spbGenerator",
        "func": "const isa_context = msg.payload.isa95_context;\nconst dataRaw = msg.payload.data;\nconst dataTimestamp = msg.payload.timestamp;\n\nconst groupId = `${isa_context.enterprise}_${isa_context.site}_${isa_context.area}`;\nconst nodeId = isa_context.line;\nconst deviceId = isa_context.equipment;\n\nconst dataMetrics = [];\nfor (const [dataName, dataValue] of Object.entries(dataRaw)) {\n    let dataType = \"String\";\n\n    if (typeof dataValue === \"number\") \n        dataType = Number.isInteger(dataValue) ? \"Int32\" : \"Double\";\n    else if (typeof dataValue === \"boolean\")\n        dataType = \"Boolean\"\n        \n    dataMetrics.push({\n        name: dataName,\n        value: dataValue,\n        type: dataType,\n        timestamp: dataTimestamp\n    });\n}\n\nmsg.topic = `spBv1.0/${groupId}/DDATA/${nodeId}/${deviceId}`;\nmsg.payload = {\n    metrics: dataMetrics\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 140,
        "wires": [
            [
                "0ef6473adffcd429",
                "f0158cfd43983707",
                "bb9d3d5d27646cc2",
                "4b39ced9533d7a88"
            ]
        ]
    },
