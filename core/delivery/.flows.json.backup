    {
        "id": "67e473f58890e577",
        "type": "link out",
        "z": "20080e9522dba17a",
        "g": "3cae7c106a179c06",
        "name": "RequestConfig",
        "mode": "link",
        "links": [
            "01fbaf9d9951d14a"
        ],
        "x": 620,
