    {
        "id": "21c35530601a19d7",
        "type": "function",
        "z": "be71d2b93d53caac",
        "g": "fd50d99e0df2f9e4",
        "name": "bufferDistributor",
        "func": "const respostaApi = msg.payload;\n\nif (respostaApi && respostaApi.status === \"success\" && Array.isArray(respostaApi.data)) {\n    const pacotes = respostaApi.data;\n    \n    if (pacotes.length > 0) {\n        node.status({ fill: \"blue\", shape: \"dot\", text: `Injetando ${pacotes.length} retidos` });\n        \n        pacotes.forEach(pacote => {\n            let msgRecuperada = {\n                topic: \"data\", \n                payload: pacote\n            };\n            \n            node.send(msgRecuperada);\n        });\n        \n    } else {\n        node.status({ fill: \"grey\", shape: \"ring\", text: \"Buffer estava vazio\" });\n    }\n} else {\n    node.error(\"Resposta inesperada da API de Buffer\", msg);\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 340,
        "wires": [
            [
                "d79fbae1969217e0"
            ]
        ]
    },
