    {
        "id": "6f9671d7a3dfdabf",
        "type": "function",
        "z": "f4a91dd7bfc833e7",
        "g": "ba6a1b32fd321ca2",
        "name": "retentionRouter",
        "func": "const client = global.get(\"mqttClient\");\nconst contextPayload = msg.payload;\n\nif (contextPayload.data) {\n\n    if (client && client.connected) {\n        node.status({ fill: \"green\", shape: \"dot\", text: \"Connector Online\" });\n        node.send([msg, null]);\n    }\n\n    else {\n        node.status({ fill: \"yellow\", shape: \"ring\", text: \"Connector Offline - Salvando na API\" });\n        \n        let msgHttp = {\n            method: \"POST\",\n            url: \"http://sida-core:8080/api/buffer\",\n            headers: { \"Content-Type\": \"application/json\" },\n            payload: contextPayload\n        };\n        \n        node.send([null, msgHttp]);\n    }\n} else {\n    node.send([msg, null]);\n}\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
