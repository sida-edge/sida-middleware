    {
        "id": "1ed9ef381529fe5c",
        "type": "function",
        "z": "f4a91dd7bfc833e7",
        "g": "ba6a1b32fd321ca2",
        "name": "DeliveryProcessor",
        "func": "const manifest = global.get(\"manifest\");\nconst gateway_id = global.get(\"gateway_id\");\nconst site = `${manifest.config.plant.enterprise}_${manifest.config.plant.site}`;\nconst spB = sparkplugPayload.get(\"spBv1.0\");\n\nif (msg.topic === \"connection_status\") {\n    let seq = 0;\n    global.set(\"spb_seq\", seq);\n    global.set(\"born_devices\", {});\n\n    const nBirthPayload = spB.encodePayload({\n        timestamp: Date.now(),\n        metrics: [{ name: \"Node Control/Rebirth\", type: \"Boolean\", value: false }],\n        seq: seq\n    });\n\n    global.set(\"spb_seq\", (seq + 1) % 256);\n\n    msg.topic = `spBv1.0/${site}/NBIRTH/${gateway_id}`;\n    msg.payload = nBirthPayload;\n    node.send(msg);\n    return;\n}\n\nif (msg.payload.data) {\n    const contextPayload = msg.payload;\n\n    if (!contextPayload || !contextPayload.asset_context || !contextPayload.data) {\n        node.error(\"Payload SIDA inválido ou sem contexto ISA-95.\");\n        return;\n    }\n\n    const pathItems = contextPayload.asset_context.path;\n    const device_id = pathItems\n        .filter(p => [\"area\", \"line\", \"equipment\"].includes(p.type))\n        .map(p => p.id)\n        .join('_');\n\n    function mapSpbType(type) {\n        const typeMap = { \"float\": \"Float\", \"double\": \"Double\", \"int\": \"Int32\", \"integer\": \"Int32\", \"boolean\": \"Boolean\", \"string\": \"String\" };\n        return typeMap[type.toLowerCase()] || \"String\";\n    }\n\n    const spbMetrics = contextPayload.data.map(d => {\n        let metric = { name: d.name, type: mapSpbType(d.data_type), value: d.value };\n        if (d.unit) {\n            metric.properties = { \"engUnit\": { type: \"String\", value: d.unit } };\n        }\n        return metric;\n    });\n\n    let seq = global.get(\"spb_seq\") || 0;\n    let bornDevices = global.get(\"born_devices\") || {};\n\n    if (!bornDevices[device_id]) {\n        const dBirthPayload = spB.encodePayload({\n            timestamp: contextPayload.timestamp,\n            metrics: spbMetrics,\n            seq: seq\n        });\n\n        node.send({\n            topic: `spBv1.0/${site}/DBIRTH/${gateway_id}/${device_id}`,\n            payload: dBirthPayload\n        });\n\n        bornDevices[device_id] = true;\n        global.set(\"born_devices\", bornDevices);\n        seq = (seq + 1) % 256;\n    }\n\n    const dDataPayload = spB.encodePayload({\n        timestamp: contextPayload.timestamp,\n        metrics: spbMetrics,\n        seq: seq\n    });\n\n    global.set(\"spb_seq\", (seq + 1) % 256);\n\n    node.send({\n        topic: `spBv1.0/${site}/DDATA/${gateway_id}/${device_id}`,\n        payload: dDataPayload\n    });\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
