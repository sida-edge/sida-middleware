        "z": "f4a91dd7bfc833e7",
        "d": true,
        "name": "JSON Length",
        "func": "const jsonText = JSON.stringify(msg.payload);\nconst jsonLength = Buffer.byteLength(jsonText, 'utf8');\n\nnode.warn(\"📊 Tamanho do JSON bruto: \" + jsonLength + \" bytes\");\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
