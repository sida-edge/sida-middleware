    {
        "id": "d066b0653a83c8c3",
        "type": "function",
        "z": "9e19e885c5971d19",
        "name": "Polling",
        "func": "const active_clients = global.get(\"modbus_clients\");\nnode.warn(active_clients);\nif (!active_clients) return null;\n\nlet timers = context.get(\"timersAtivos\") || {};\nfor(let key in timers) {\n    clearInterval(timers[key]);\n}\ntimers = {};\n\nObject.keys(active_clients).forEach((deviceId) => {\n    const { client, config, gateway_id } = active_clients[deviceId]\n\n    const scanRate = config.connection.scan_rate_ms || 1000;\n    const metrics = config.metrics_mapping || {};\n\n    let intervalId = setInterval(async () => {\n        if (!client.isOpen) return;\n        try {\n            let data_payload = {};\n            for (let addrKey of Object.keys(metrics)) {\n                const metric = metrics[addrKey];\n\n                let address = parseInt(addrKey);\n                if (address >= 40001 && address <= 49999) address -= 40001;\n                else if (address >= 30001 && address <= 39999) address -= 30001;\n\n                let quantity = (metric.data_type === \"float\" || metric.data_type === \"int32\") ? 2 : 1;\n                if (metric.data_type == \"double\" || metric.data_type == \"int64\") quantity = 4;\n\n                let data;\n                if (metric.register_type === \"holding\" || addrKey.startsWith(\"4\"))\n                    data = await client.readHoldingRegisters(address, quantity);\n                else if (metric.register_type === \"input\" || addrKey.startsWith(\"3\"))\n                    data = await client.readInputRegisters(address, quantity); \n\n                data_payload[addrKey] = (data.data.length === 1) ? data.data[0] : data.data;\n            }\n            node.warn(msg.payload);\n\n            node.send({\n                payload: {\n                    timestamp: Date.now(),\n                    gateway_id: gateway_id,\n                    source: {\n                        device_id: deviceId,\n                        source_protocol: config.connection.protocol\n                    },\n                    data: data_payload\n                }\n            });\n        } catch (erro) {\n            node.warn(`[Messaging] Erro de leitura em ${deviceId}: ${erro.message}`);\n        }\n    }, scanRate);\n\n    timers[deviceId] = intervalId;\n});\n\ncontext.set(\"timersAtivos\", timers);\nnode.status({ fill: \"green\", shape: \"dot\", text: \"Lendo e processando...\" });\n\nnode.on(\"close\", function () {\n    let timersAtivos = context.get(\"timersAtivos\") || {};\n    for (let key in timersAtivos) clearInterval(timersAtivos[key]);\n    context.set(\"timersAtivos\", {});\n});\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
