    {
        "id": "ccea0bf949fb23b4",
        "type": "function",
        "z": "bf8d16b5667222e0",
        "g": "8ef01d727620bf3e",
        "name": "setupModbus",
        "func": "(async function () {\n    const manifest = global.get(\"manifest\");\n    const gateway_id = global.get(\"gateway_id\");\n\n    node.warn(manifest);\n\n    if (!manifest || !manifest.config || !manifest.config.plant || !manifest.config.plant.areas) {\n        node.warn(\"Manifesto inválido no Messaging. Estrutura de Planta/Áreas ausente.\");\n        return;\n    }\n\n    let active_clients = global.get(\"modbus_clients\") || {};\n\n    for (let id in active_clients) {\n        if (active_clients[id].client && active_clients[id].client.isOpen) {\n            active_clients[id].client.close();\n        }\n    }\n\n    active_clients = {};\n    const areas = manifest.config.plant.areas;\n\n    for (const areaId of Object.keys(areas)) {\n        const lines = areas[areaId].lines || {};\n        for (const lineId of Object.keys(lines)) {\n            const devices = lines[lineId].devices || {};\n            for (const deviceId of Object.keys(devices)) {\n                const dev = devices[deviceId];\n                if (dev.enabled !== true || dev.connection.protocol !== \"modbus_tcp\") {\n                    continue;\n                }\n                const client = new ModbusRTU();\n\n                try {\n                    await client.connectTCP(dev.connection.host, { port: dev.connection.port || 502 });\n                    client.setID(dev.connection.unit_id || 1);\n\n                    active_clients[deviceId] = {\n                        client: client,\n                        config: dev,\n                        gateway_id: gateway_id\n                    };\n\n                    node.warn(`[Messaging] Conexão ESTABELECIDA com ${deviceId}`);\n                } catch (erro) {\n                    node.warn(`[Messaging] Erro ao conectar com ${deviceId}: ${erro.message}`);\n                }\n            }\n        }\n    }\n\n    global.set(\"modbus_clients\", active_clients);\n    node.warn(\"Clientes ativos no momento: \" + Object.keys(active_clients).length);\n\n    msg.payload = \"Running\";\n    node.send(msg);\n\n})();\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
            {
                "var": "ModbusRTU",
                "module": "modbus-serial"
            }
        ],
        "x": 600,
        "y": 380,
        "wires": [
            [
                "8cbeb60de162ae13"
            ]
        ]
